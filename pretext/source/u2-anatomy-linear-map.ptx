        <li><p><url href="https://math.libretexts.org/Bookshelves/Linear_Algebra/Linear_Algebra_with_Applications_(Nicholson)/03%3A_Determinants_and_Diagonalization/3.02%3A_Determinants_and_Matrix_Inverses/3.2E%3A_Determinants_and_Matrix_Inverses_Exercises">Nicholson 3.2.6(b)</url></p></li>
        <li><p><url href="https://math.libretexts.org/Bookshelves/Linear_Algebra/Linear_Algebra_with_Applications_(Nicholson)/03%3A_Determinants_and_Diagonalization/3.01%3A_The_Cofactor_Expansion/3.1E%3A_The_Cofactor_Expansion_Exercises">Nicholson 3.1.1(h)</url></p></li>
